// Firestore security rules for Lukis.
// Each signed-in user can read and write only their own bookings.
// Publish these in the Firebase console (Firestore -> Rules) or via the CLI.
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/entries/{entryId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
